# ─────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values. Never commit the
# real `.env` (it's already in .gitignore). When you deploy on
# Vercel, add every one of these under Project Settings → Environment
# Variables too — .env only works for local `npm run dev`.
# ─────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
#   SUPABASE_URL             = "Project URL"
#   SUPABASE_ANON_KEY        = "anon public" key
#   SUPABASE_SERVICE_ROLE_KEY = "service_role" key (SECRET — server-only,
#                               used by /api/* and scripts/seed-admin.ts.
#                               Never expose this to the browser.)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Prisma / Postgres ────────────────────────────────────────────
# Supabase Dashboard → Project Settings → Database → Connection string
#   DATABASE_URL = the "Transaction" pooled connection string (port 6543)
#                   — used at runtime by the serverless functions.
#   DIRECT_URL   = the "Session"/direct connection string (port 5432)
#                   — used only by `prisma migrate`.
# Both look like: postgresql://postgres.[project-ref]:[password]@...
DATABASE_URL=
DIRECT_URL=

# ── Resend (email alerts on new Contact Us submissions) ─────────
# resend.com → API Keys → Create API Key
RESEND_API_KEY=
# The address that receives the "new contact query" alert email.
CONTACT_ALERT_EMAIL=
# Must be a verified sender/domain in Resend. Resend's shared sandbox
# address works for testing without verifying your own domain:
RESEND_FROM_EMAIL="Portfolio Contact <onboarding@resend.dev>"

# ── Google reCAPTCHA v3 (admin login page) ───────────────────────
# https://www.google.com/recaptcha/admin/create — register a v3 site
#   VITE_RECAPTCHA_SITE_KEY = the "Site key" (safe to expose client-side)
#   RECAPTCHA_SECRET_KEY    = the "Secret key" (server-only)
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ── Admin seed account (used once, by `npm run seed:admin`) ─────
# Pick the email/password you want to log into /admin/login with.
# Not read anywhere else — safe to leave blank after seeding.
ADMIN_SEED_NAME="Asad Ali"
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
